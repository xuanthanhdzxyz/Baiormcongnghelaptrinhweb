@model Bai6_Validation.Models.EventImage_bit240215

@{
    ViewData["Title"] = "Thêm ảnh cho sự kiện";
}

<h2>🖼️ Thêm ảnh cho sự kiện</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="AddImage" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EventId" />

            <div class="form-group mb-3">
                <label>Sự kiện</label>
                <input type="text" class="form-control" value="@ViewBag.EventName" disabled />
            </div>

            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="control-label"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
                <small class="text-muted">Nhập URL của ảnh</small>
            </div>

            <div class="form-group form-check mb-3">
                <input asp-for="IsThumbnail" class="form-check-input" />
                <label asp-for="IsThumbnail" class="form-check-label"></label>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">💾 Lưu ảnh</button>
                <a asp-action="Detail" asp-route-id="@Model.EventId" class="btn btn-secondary">↩️ Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}