@model List<Bai6_Validation.Models.Book>

@{
    ViewData["Title"] = "Danh sách sách";
}

<h2>📚 Danh sách sách</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        ✅ @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">➕ Thêm sách mới</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tên sách</th>
            <th>Giá</th>
            <th>Tác giả</th>
            <th>Nhà xuất bản</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Id</td>
                    <td>@book.Ten</td>
                    <td>@book.Gia.ToString("N0") USD</td>
                    <td>@(string.IsNullOrEmpty(book.TacGia) ? "---" : book.TacGia)</td>
                    <td>@(string.IsNullOrEmpty(book.NhaXuatBan) ? "---" : book.NhaXuatBan)</td>
                    <td>
                        <a asp-action="Detail" asp-route-id="@book.Id" class="btn btn-info btn-sm">🔍 Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-warning btn-sm">✏️ Sửa</a>
                        <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-danger btn-sm">🗑️ Xóa</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">📭 Chưa có sách nào</td>
            </tr>
        }
    </tbody>
</table>